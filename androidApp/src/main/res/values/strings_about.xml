    <!-- How it works -->
    <string name="about_step1_title">Listen to the reference</string>
    <string name="about_step1_desc">Choose Vivian or Aiden as your reference voice and listen to the correct pronunciation.</string>
    <string name="about_step2_title">Record yourself</string>
    <string name="about_step2_desc">Tap the microphone and speak the sentence clearly.</string>
    <string name="about_step3_title">On-device phonetic analysis</string>
    <string name="about_step3_desc">Your recording is converted to IPA phonemes by Allosaurus (English) or Wav2Vec2 (French), running entirely offline on your device.</string>
    <string name="about_step4_title">Get color-coded feedback</string>
    <string name="about_step4_desc">Each letter is colored — white for correct, orange for close, red for missed — so you know exactly what to improve.</string>
    <string name="about_step5_title">Master the batch</string>
    <string name="about_step5_desc">Practice in batches of 10 sentences. Failed sentences reappear until all 10 reach 85%% accuracy.</string>

