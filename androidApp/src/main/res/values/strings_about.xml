    <!-- Privacy -->
    <string name="about_privacy_title">100%% On-Device</string>
    <string name="about_privacy_body">All phonetic analysis runs entirely on your device using a local ONNX model. Your voice recordings are never uploaded anywhere, no account is required, and no usage data is collected.</string>

    <!-- Source code -->
    <string name="about_source_title">Open Source — AGPLv3</string>
