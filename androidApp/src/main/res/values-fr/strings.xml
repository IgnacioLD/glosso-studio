    <!-- Privacy -->
    <string name="about_privacy_title">100%% sur l\'appareil</string>
    <string name="about_privacy_body">Toute l\'analyse phonétique s\'exécute entièrement sur votre appareil via un modèle ONNX local. Vos enregistrements vocaux ne sont jamais envoyés en ligne, aucun compte n\'est requis et aucune donnée d\'utilisation n\'est collectée.</string>

    <!-- Source code -->
    <string name="about_source_title">Open source — AGPLv3</string>
    <string name="about_source_body">Glosso Studio est un logiciel libre et open source. Vous êtes libre de l\'étudier, de le modifier et de le redistribuer selon les termes de la GNU Affero General Public License v3.</string>
    <string name="about_link_source_code">Code source</string>
    <string name="about_link_report_issue">Signaler un problème</string>

    <!-- How it works -->
    <string name="about_step1_title">Écoutez la référence</string>
    <string name="about_step1_desc">Choisissez Vivian ou Aiden comme voix de référence et écoutez la prononciation correcte.</string>
    <string name="about_step2_title">Enregistrez-vous</string>
    <string name="about_step2_desc">Appuyez sur le microphone et prononcez la phrase clairement.</string>
    <string name="about_step3_title">Analyse phonétique sur l\'appareil</string>
    <string name="about_step3_desc">Votre enregistrement est converti en phonèmes API par Allosaurus (anglais) ou Wav2Vec2 (français), fonctionnant entièrement hors ligne sur votre appareil.</string>
    <string name="about_step4_title">Recevez un retour coloré</string>
    <string name="about_step4_desc">Chaque lettre est colorée — blanc pour correct, orange pour proche, rouge pour manqué — pour que vous sachiez exactement quoi améliorer.</string>
    <string name="about_step5_title">Maîtrisez la série</string>
    <string name="about_step5_desc">Entraînez-vous par séries de 10 phrases. Les phrases échouées réapparaissent jusqu\'à ce que les 10 atteignent 85%% de précision.</string>

