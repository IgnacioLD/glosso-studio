    <!-- Privacy -->
    <string name="about_privacy_title">100%% en el dispositivo</string>
    <string name="about_privacy_body">Todo el análisis fonético se ejecuta completamente en tu dispositivo usando un modelo ONNX local. Tus grabaciones de voz nunca se suben a ningún sitio, no se requiere cuenta y no se recopilan datos de uso.</string>

