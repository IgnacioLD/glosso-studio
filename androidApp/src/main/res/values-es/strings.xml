    <string name="about_link_source_code">Código fuente</string>
    <string name="about_link_report_issue">Reportar problema</string>

    <!-- How it works -->
    <string name="about_step1_title">Escucha la referencia</string>
    <string name="about_step1_desc">Elige a Vivian o Aiden como tu voz de referencia y escucha la pronunciación correcta.</string>
    <string name="about_step2_title">Grábate</string>
    <string name="about_step2_desc">Toca el micrófono y di la oración con claridad.</string>
    <string name="about_step3_title">Análisis fonético en el dispositivo</string>
    <string name="about_step3_desc">Tu grabación se convierte en fonemas IPA mediante Allosaurus (inglés) o Wav2Vec2 (francés), que se ejecutan totalmente sin conexión en tu dispositivo.</string>
    <string name="about_step4_title">Recibe retroalimentación con colores</string>
    <string name="about_step4_desc">Cada letra se colorea — blanco si es correcta, naranja si está cerca, rojo si es incorrecta — así sabes exactamente qué mejorar.</string>
    <string name="about_step5_title">Domina el lote</string>
    <string name="about_step5_desc">Practica en lotes de 10 oraciones. Las oraciones fallidas reaparecen hasta que las 10 alcancen el 85%% de precisión.</string>

